# --- Zazyvala Bot Settings ---
BOT_TOKEN=your_zazyvala_bot_token
ADMIN_ID=your_telegram_id
CHAT_ID=-1001234567890

# --- Biblia Bot Settings ---
BIBLIA_BOT_TOKEN=your_biblia_bot_token
BIBLIA_DAILY_QUOTE_TIMES=09:00,21:00
BIBLIA_TIMEZONE=Europe/Moscow

# --- Database (PostgreSQL/Neon.tech) ---
# Use the same URL for both or separate ones if needed
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
BIBLIA_DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# --- Deployment ---
RENDER=true
PORT=8080
